{
  "name": "my-paywall-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/server/index.ts",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "fly:secrets": "pwsh -File scripts/fly-set-secrets.ps1",
    "fly:deploy": "pwsh -File scripts/fly-deploy-prod.ps1",
    "build:server": "tsc --project tsconfig.node.json",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "wrangler d1 migrations apply my-paywall-db --local",
    "db:studio": "drizzle-kit studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --testPathPattern=tests/",
    "test:backend": "jest tests/backend.test.ts",
    "test:frontend": "jest tests/frontend.test.tsx",
    "test:hooks": "jest tests/hooks.test.ts",
    "test:integration": "jest tests/integration.test.ts"
  },
  "dependencies": {
    "@better-auth/cli": "^1.4.21",
    "@stripe/stripe-js": "^9.12.0",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jest": "^30.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "msw": "^2.15.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "wrangler": "^4.113.0"
  }
}
